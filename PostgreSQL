-- ============================================================
-- PROJECT: Shopify Sales Analytics
-- DATABASE: PostgreSQL
-- AUTHOR: Annu Sangwan
-- DESCRIPTION:
-- SQL queries for analyzing Shopify sales data and generating
-- KPIs for an Excel dashboard.
-- ============================================================

---------------------------------------------------------------
-- DROP TABLE
---------------------------------------------------------------

DROP TABLE IF EXISTS ecommerce_sales;

---------------------------------------------------------------
-- CREATE TABLE
---------------------------------------------------------------

CREATE TABLE ecommerce_sales (
    order_id INT,
    order_date DATE,
    customer_id INT,
    product_id INT,
    product_category VARCHAR(100),
    product_price DECIMAL(10,2),
    discount_percent DECIMAL(5,2),
    quantity INT,
    customer_country VARCHAR(100),
    traffic_source VARCHAR(50),
    payment_method VARCHAR(50),
    shipping_cost DECIMAL(6,2),
    rating DECIMAL(2,1),
    is_returned BOOLEAN,
    discounted_price DECIMAL(10,2),
    revenue DECIMAL(12,2),
    profit DECIMAL(12,2)
);

---------------------------------------------------------------
-- VIEW SAMPLE DATA
---------------------------------------------------------------

SELECT *
FROM ecommerce_sales
LIMIT 10;

---------------------------------------------------------------
-- KPI 1 : Total Revenue
---------------------------------------------------------------

SELECT
    SUM(quantity * discounted_price) AS total_revenue
FROM ecommerce_sales;

---------------------------------------------------------------
-- KPI 2 : Total Orders
---------------------------------------------------------------

SELECT
    COUNT(DISTINCT order_id) AS total_orders
FROM ecommerce_sales;

---------------------------------------------------------------
-- KPI 3 : Total Customers
---------------------------------------------------------------

SELECT
    COUNT(DISTINCT customer_id) AS total_customers
FROM ecommerce_sales;

---------------------------------------------------------------
-- KPI 4 : Average Order Value (AOV)
---------------------------------------------------------------

SELECT
    SUM(quantity * discounted_price) AS total_revenue,
    COUNT(DISTINCT order_id) AS total_orders,
    ROUND(
        SUM(quantity * discounted_price) /
        COUNT(DISTINCT order_id),2
    ) AS average_order_value
FROM ecommerce_sales;

---------------------------------------------------------------
-- KPI 5 : Total Profit
---------------------------------------------------------------

SELECT
    SUM(profit) AS total_profit
FROM ecommerce_sales;

---------------------------------------------------------------
-- Revenue by Product Category
---------------------------------------------------------------

SELECT
    product_category,
    SUM(quantity * discounted_price) AS total_revenue
FROM ecommerce_sales
GROUP BY product_category
ORDER BY total_revenue DESC;

---------------------------------------------------------------
-- Profit by Product Category
---------------------------------------------------------------

SELECT
    product_category,
    SUM(profit) AS total_profit
FROM ecommerce_sales
GROUP BY product_category
ORDER BY total_profit DESC;

---------------------------------------------------------------
-- Orders by Payment Method
---------------------------------------------------------------

SELECT
    payment_method,
    COUNT(DISTINCT order_id) AS total_orders
FROM ecommerce_sales
GROUP BY payment_method
ORDER BY total_orders DESC;

---------------------------------------------------------------
-- Revenue by Traffic Source
---------------------------------------------------------------

SELECT
    traffic_source,
    SUM(quantity * discounted_price) AS total_revenue
FROM ecommerce_sales
GROUP BY traffic_source
ORDER BY total_revenue DESC;

---------------------------------------------------------------
-- Revenue by Country
---------------------------------------------------------------

SELECT
    customer_country,
    SUM(quantity * discounted_price) AS total_revenue
FROM ecommerce_sales
GROUP BY customer_country
ORDER BY total_revenue DESC;

---------------------------------------------------------------
-- Top 10 Customers by Revenue
---------------------------------------------------------------

SELECT
    customer_id,
    SUM(quantity * discounted_price) AS total_revenue
FROM ecommerce_sales
GROUP BY customer_id
ORDER BY total_revenue DESC
LIMIT 10;

---------------------------------------------------------------
-- Average Order Value by Traffic Source
---------------------------------------------------------------

SELECT
    traffic_source,
    ROUND(
        SUM(quantity * discounted_price) /
        COUNT(DISTINCT order_id),2
    ) AS average_order_value
FROM ecommerce_sales
GROUP BY traffic_source
ORDER BY average_order_value DESC;

---------------------------------------------------------------
-- Average Profit per Order by Payment Method
---------------------------------------------------------------

SELECT
    payment_method,
    ROUND(
        SUM(profit) /
        COUNT(DISTINCT order_id),2
    ) AS average_profit_per_order
FROM ecommerce_sales
GROUP BY payment_method
ORDER BY average_profit_per_order DESC;

---------------------------------------------------------------
-- Monthly Revenue Trend
---------------------------------------------------------------

SELECT
    DATE_TRUNC('month', order_date) AS month,
    SUM(quantity * discounted_price) AS total_revenue
FROM ecommerce_sales
GROUP BY month
ORDER BY month;

---------------------------------------------------------------
-- Monthly Profit Trend
---------------------------------------------------------------

SELECT
    DATE_TRUNC('month', order_date) AS month,
    SUM(profit) AS total_profit
FROM ecommerce_sales
GROUP BY month
ORDER BY month;

---------------------------------------------------------------
-- Average Order Value by Country
---------------------------------------------------------------

SELECT
    customer_country,
    ROUND(
        SUM(quantity * discounted_price) /
        COUNT(DISTINCT order_id),2
    ) AS average_order_value
FROM ecommerce_sales
GROUP BY customer_country
ORDER BY average_order_value DESC;

---------------------------------------------------------------
-- Customers by Traffic Source
---------------------------------------------------------------

SELECT
    traffic_source,
    COUNT(DISTINCT customer_id) AS total_customers
FROM ecommerce_sales
GROUP BY traffic_source
ORDER BY total_customers DESC;

---------------------------------------------------------------
-- Average Discount Percentage by Product Category
---------------------------------------------------------------

SELECT
    product_category,
    ROUND(AVG(discount_percent),2) AS average_discount
FROM ecommerce_sales
GROUP BY product_category
ORDER BY average_discount DESC;

---------------------------------------------------------------
-- Average Rating by Product Category
---------------------------------------------------------------

SELECT
    product_category,
    ROUND(AVG(rating),2) AS average_rating
FROM ecommerce_sales
GROUP BY product_category
ORDER BY average_rating DESC;

---------------------------------------------------------------
-- Top 5 Most Profitable Customers
---------------------------------------------------------------

SELECT
    customer_id,
    SUM(profit) AS total_profit
FROM ecommerce_sales
GROUP BY customer_id
ORDER BY total_profit DESC
LIMIT 5;

---------------------------------------------------------------
-- Orders Below Overall Average Profit
---------------------------------------------------------------

WITH orders_profit AS
(
    SELECT
        order_id,
        AVG(profit) AS average_profit
    FROM ecommerce_sales
    GROUP BY order_id
)

SELECT *
FROM orders_profit
WHERE average_profit <
(
    SELECT AVG(profit)
    FROM ecommerce_sales
)
ORDER BY average_profit;

---------------------------------------------------------------
-- Product Category Ranking by Revenue
---------------------------------------------------------------

SELECT
    product_category,
    SUM(revenue) AS total_revenue,
    ROW_NUMBER() OVER(
        ORDER BY SUM(revenue) DESC
    ) AS ranking
FROM ecommerce_sales
GROUP BY product_category;

---------------------------------------------------------------
-- Monthly Revenue (Year & Month)
---------------------------------------------------------------

SELECT
    EXTRACT(YEAR FROM order_date) AS year,
    EXTRACT(MONTH FROM order_date) AS month,
    SUM(revenue) AS total_revenue
FROM ecommerce_sales
GROUP BY
    EXTRACT(YEAR FROM order_date),
    EXTRACT(MONTH FROM order_date)
ORDER BY
    year,
    month;

---------------------------------------------------------------
-- Month-over-Month Revenue Growth
---------------------------------------------------------------

WITH monthly_sales AS
(
    SELECT
        EXTRACT(MONTH FROM order_date) AS month,
        SUM(revenue) AS revenue
    FROM ecommerce_sales
    GROUP BY month
)

SELECT
    month,
    revenue,
    LAG(revenue) OVER(ORDER BY month) AS previous_month,
    ROUND(
        (
            (revenue - LAG(revenue) OVER(ORDER BY month))
            /
            LAG(revenue) OVER(ORDER BY month)
        ) * 100,
        2
    ) AS growth_percentage
FROM monthly_sales
ORDER BY month;

